<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.2.0.0" ProductVersion="3.1.4026.13" Encoding="base64">
  <POU Name="StateMachine" Id="{d0abcf5f-9f24-0f8a-39bf-7fb2dc7397ff}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'linkalways'} 
{attribute 'no_explicit_call' := 'This FB is a CLASS and must be accessed using methods or properties'}
{attribute 'enable_dynamic_creation'}
FUNCTION_BLOCK PUBLIC StateMachine
VAR_GENERIC CONSTANT
	initial_state : State := State.Idle;
END_VAR
IMPLEMENTS
	AbortingCommands,
	ClearingCommands,
	HeldCommands,
	CompletingCommands,
	ExecuteCommands,
	AbortedCommands,
	CompletedCommands,
	HoldingCommands,
	UnsuspendingCommands,
	UnholdingCommands,
	SuspendingCommands,
	SuspendedCommands,
	IdleCommands,
	ResettingCommands,
	StartingCommands,
	StoppedCommands,
	StoppingCommands
VAR
	current_state : State := initial_state;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Folder Name="Private" Id="{92ee8545-cc6e-0551-032e-c757d72635dc}" />
    <Folder Name="Properties" Id="{ca173b4b-06e7-00e5-1bf0-6630be7905be}" />
    <Method Name="Abort" Id="{bb0e76c5-82c5-0194-13a0-d72d1e2b517e}">
      <Declaration><![CDATA[METHOD PUBLIC Abort]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsAborting OR IsAborted THEN
	RETURN;
END_IF

LogCommand('Abort');
ChangeState(State.Aborting);]]></ST>
      </Implementation>
    </Method>
    <Method Name="ChangeState" Id="{52457b9b-d7d8-03f7-096f-c90b7a495fb4}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE ChangeState
VAR_INPUT
	state : State;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ExitingState(current_state);
current_state := state;
EnteringState(current_state);]]></ST>
      </Implementation>
    </Method>
    <Method Name="Clear" Id="{9396148d-9c12-0773-2317-67670be02645}">
      <Declaration><![CDATA[METHOD PUBLIC Clear]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsAborted THEN
	LogCommand('Clear');
	ChangeState(State.Clearing);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="CurrentState" Id="{16c46314-cfcc-4851-8a6d-f06982f9a9f8}" FolderPath="Properties\">
      <Declaration><![CDATA[{attribute 'monitoring':='call'}
PROPERTY PUBLIC CurrentState : State]]></Declaration>
      <Get Name="Get" Id="{d88cbc08-e52c-4a38-9f19-cd53f85e2ca5}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[CurrentState := current_state;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="EnteringState" Id="{1efb7a44-a0ad-0db2-0376-3a7458e62fe6}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE EnteringState
VAR_INPUT
	state : State;
END_VAR
VAR
	state_string : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[state_string := TO_STRING(state);]]></ST>
      </Implementation>
    </Method>
    <Method Name="ExitingState" Id="{dd71a62b-774d-023f-204c-c7ab4bf8d0bd}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE ExitingState
VAR_INPUT
	state : State;
END_VAR
