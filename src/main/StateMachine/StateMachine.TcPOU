      </Get>
    </Property>
    <Method Name="LogCommand" Id="{37762c3a-2d13-0cbb-21a5-6960acdd3080}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE LogCommand
VAR_INPUT
	command : STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{d90e7afe-b91e-0cda-1d6c-c4d6ece2bbff}">
      <Declaration><![CDATA[METHOD PUBLIC Reset]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsStopped OR IsCompleted THEN
	LogCommand('Reset');
	ChangeState(State.Resetting);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Start" Id="{6c176fd0-4cce-0324-27f8-3c5c37427ff9}">
      <Declaration><![CDATA[METHOD PUBLIC Start]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsIdle THEN
	LogCommand('Start');
	ChangeState(State.Starting);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="StateComplete" Id="{c682b564-7529-04fa-0c1e-e9fdfee0251d}">
      <Declaration><![CDATA[METHOD PUBLIC StateComplete]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE current_state OF 
	State.Idle:
		RETURN;
	
	State.Starting:
		ChangeState(State.Execute);
		
	State.Execute:
		ChangeState(State.Completing);
		
	State.Completing:
		ChangeState(State.Completed);
	
	State.Completed:
		RETURN;
	
	State.Stopping:
		ChangeState(State.Stopped);
	
	State.Stopped:
		RETURN;
	
	State.Resetting:
		ChangeState(State.Idle);
	
	State.Holding:
		ChangeState(State.Held);
	
	State.Held:
		RETURN;
	
	State.Unholding:
		ChangeState(State.Execute);
	
	State.Suspending:
		ChangeState(State.Suspended);
	
	State.Suspended:
		RETURN;
	
	State.Unsuspending:
		ChangeState(State.Execute);
	
	State.Clearing:
		ChangeState(State.Stopped);
	
	State.Aborted:
		RETURN;
	
	State.Aborting:
		ChangeState(State.Aborted);
END_CASE

LogCommand('StateComplete');]]></ST>
      </Implementation>
    </Method>
    <Method Name="Stop" Id="{d82a4727-6fb4-0660-1c24-5c5fff9a3863}">
      <Declaration><![CDATA[METHOD PUBLIC Stop]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE current_state OF
	State.Stopped: RETURN;
	State.Stopping: RETURN;
	State.Clearing: RETURN;
	State.Aborted: RETURN;
	State.Aborting: RETURN;
END_CASE

LogCommand('Stop');
ChangeState(State.Stopping);]]></ST>
      </Implementation>
    </Method>
    <Method Name="Suspend" Id="{a96858af-5616-0da7-2a1c-0ce19a6c099b}">
      <Declaration><![CDATA[METHOD PUBLIC Suspend]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsExecuting THEN 
	LogCommand('Suspend');
	ChangeState(State.Suspending);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Unhold" Id="{47f76631-27ec-03a3-0f29-4412d04e3f01}">
      <Declaration><![CDATA[METHOD PUBLIC Unhold]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsHeld THEN
	LogCommand('Unhold');
	ChangeState(State.Unholding);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Unsuspend" Id="{730f864a-e830-0a73-1517-45aa7fa3d026}">
      <Declaration><![CDATA[METHOD PUBLIC Unsuspend]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsSuspended THEN
	LogCommand('Unsuspend');
	ChangeState(State.Unsuspending);
END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>