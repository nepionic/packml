END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[state_string := TO_STRING(state);]]></ST>
      </Implementation>
    </Method>
    <Method Name="Hold" Id="{98bda4c7-ff86-0dff-1078-c505b4eb1fca}">
      <Declaration><![CDATA[METHOD PUBLIC Hold]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsExecuting THEN
	LogCommand('Hold');
	ChangeState(State.Holding);
END_IF]]></ST>
      </Implementation>
    </Method>
